# TAPMC source
SOURCE_URL=https://www.tapmc.com.tw/Pages/Trans/Price1

# Google Sheet settings
GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/service-account.json
# 雲端執行可改用 JSON 文字內容（例如 GitHub Secret）
GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT=
GOOGLE_SHEET_ID=your_google_sheet_id
ITEM_WORKSHEET_NAME=item
ITEM_COLUMN=1

# Timezone
TIMEZONE=Asia/Taipei

# category:fv_code:market
# category: 1=場內拍賣行情, 2=全場交易行情
# fv_code: V=蔬菜, F=水果
# market: 1=一市, 2=二市
QUERY_COMBOS=1:V:1,1:F:1,2:V:1,2:V:2,2:F:1,2:F:2

# 指定查詢日期(民國YYY/MM/DD)，留空=今天
QUERY_DATE_ROC=
# 休市時最多往前找幾天
MAX_BACKTRACK_DAYS=10

# AMIS 區間品項上價平均
# 日期來源：sheet（從 Google Sheet 的 DATE_RANGE1/DATE_RANGE2 讀取）或 env（讀 DATE_START/DATE_END）
DATE_INPUT_SOURCE=sheet
DATE_START=
DATE_END=
DATE_RANGE1_START_CELL=B1
DATE_RANGE1_END_CELL=B2
DATE_RANGE2_START_CELL=C1
DATE_RANGE2_END_CELL=C2

# 輸出分頁與寫入設定
WORKSHEET_NAME=
OUTPUT_START_CELL=A1
CLEAR_BEFORE_WRITE=true
DRY_RUN=false

# AMIS 來源與市場
SOURCE_VEG_URL=https://amis.afa.gov.tw/veg/VegProdDayTransInfo.aspx
SOURCE_FRUIT_URL=https://amis.afa.gov.tw/fruit/FruitProdDayTransInfo.aspx
SOURCE_VEG_SELECTOR_URL=https://amis.afa.gov.tw/Selector/VegProductSelector.aspx?textField=ctl00_contentPlaceHolder_txtProduct&valueField=ctl00_contentPlaceHolder_hfldProductNo&productTypeField=ctl00_contentPlaceHolder_hfldProductType
SOURCE_FRUIT_SELECTOR_URL=https://amis.afa.gov.tw/Selector/FruitProductSelector.aspx?textField=ctl00_contentPlaceHolder_txtProduct&valueField=ctl00_contentPlaceHolder_hfldProductNo&productTypeField=ctl00_contentPlaceHolder_hfldProductType
MARKET_NO=109
MARKET_NAME=北市一
SSL_VERIFY=true
CHUNK_SIZE=120
MAX_PRODUCTS=0
ALL_PRODUCTS=true
